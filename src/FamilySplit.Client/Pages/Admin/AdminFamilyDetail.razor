@page "/admin/families/{FamilyId:guid}"
@using FamilySplit.Client.Store.Admin
@using FamilySplit.Client.Store.FamilyMembers
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IDispatcher Dispatcher
@inject IState<AdminState> State
@inject IState<FamilyMemberState> ProfileState
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject I18nText I18nText

<PageTitle>Admin · Family — FamilySplit</PageTitle>

<RequireAdmin />

@if (State.Value.IsLoading && State.Value.SelectedFamily is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    return;
}

@if (State.Value.ErrorMessage is not null && State.Value.SelectedFamily is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@State.Value.ErrorMessage</MudAlert>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/admin"))">
        @_t.Back
    </MudButton>
    return;
}

@{
    var family = State.Value.SelectedFamily;
    if (family is null) return;
}

<MudBreadcrumbs Items="_crumbs" Class="mb-2" />

<PageErrorBanner ErrorMessage="@State.Value.ErrorMessage"
                 OnDismiss="@(() => Dispatcher.Dispatch(new ClearAdminErrorAction()))" />

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1" Wrap="Wrap.Wrap">
    <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom" Color="Color.Primary" Size="Size.Large" />
    <MudText Typo="Typo.h5">@family.Name</MudText>
    <MudChip T="string" Color="Color.Error" Size="Size.Small">@_t.GlobalAdminChip</MudChip>
    @if (IsOwnFamily)
    {
        <MudChip T="string" Color="Color.Info" Size="Size.Small"
                 Icon="@Icons.Material.Filled.Home">@_t.YourFamilyChip</MudChip>
    }
</MudStack>
<MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
    ID: @family.Id · Created @family.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
</MudText>

<SectionHeader Title="@_t.Members">
    <Actions>
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Medium"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenAddMemberDialog">
            @_t.AddMember
        </MudButton>
    </Actions>
</SectionHeader>

@if (!family.Members.Any())
{
    <MudAlert Severity="Severity.Info" Class="mb-4">@_t.AdminFamilyMembersEmpty</MudAlert>
}
else
{
    <MudTable Items="family.Members"
              Dense="true"
              Hover="true"
              Elevation="1"
              Class="mb-6">
        <HeaderContent>
            <MudTh>@_t.ColName</MudTh>
            <MudTh>@_t.ColEmail</MudTh>
            <MudTh>@_t.ColWeight</MudTh>
            <MudTh>Tier</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="width:80px"></MudTh>
        </HeaderContent>
        <RowTemplate Context="member">
            <MudTd DataLabel="@_t.ColName">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Size="Size.Small" Color="Color.Primary">@member.DisplayName[0]</MudAvatar>
                    <MudText>@member.DisplayName</MudText>
                </MudStack>
            </MudTd>
            <MudTd DataLabel="@_t.ColEmail">
                <MudText Typo="Typo.body2">@(member.Email ?? "—")</MudText>
            </MudTd>
            <MudTd DataLabel="@_t.ColWeight">@member.CurrentWeight.ToString("0.##")×</MudTd>
            <MudTd DataLabel="Tier">
                <WeightBadge Tier="member.CurrentTier" Weight="member.CurrentWeight" />
            </MudTd>
            <MudTd DataLabel="Role">
                <MemberRoleChip IsAdmin="member.IsAdmin" />
            </MudTd>
            <MudTd DataLabel="Status">
                <MemberStatusChip IsLinked="member.IsLinked" HasEmail="member.Email is not null" />
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="0">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Medium"
                                   title="Edit member"
                                   OnClick="@(() => OpenEditMemberDialog(member))" />
                    @if (member.Id != MyMemberId)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                       Size="Size.Medium"
                                       Color="Color.Error"
                                       title="@_t.RemoveMember"
                                       OnClick="@(() => ConfirmRemoveMember(member))" />
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public Guid FamilyId { get; set; }

    private AppText _t = new();
    private Guid?  MyMemberId  => ProfileState.Value.MyProfile?.Id;
    private bool   IsOwnFamily => MyMemberId.HasValue &&
                                  (State.Value.SelectedFamily?.Members.Any(m => m.Id == MyMemberId.Value) ?? false);

    private List<BreadcrumbItem> _crumbs = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _t = await I18nText.GetTextTableAsync<AppText>(this);
        _crumbs =
        [
            new BreadcrumbItem(_t.NavAdmin, href: "/admin"),
            new BreadcrumbItem(_t.NavFamily, href: null, disabled: true)
        ];
        Dispatcher.Dispatch(new LoadAdminFamilyAction(FamilyId));
        if (ProfileState.Value.MyProfile is null)
            Dispatcher.Dispatch(new LoadMyProfileAction());
    }

    protected override void OnParametersSet()
    {
        if (State.Value.SelectedFamily?.Id != FamilyId)
            Dispatcher.Dispatch(new LoadAdminFamilyAction(FamilyId));
    }

    private async Task OpenAddMemberDialog()
    {
        var dialog = await DialogService.ShowAsync<FamilyMemberDialog>(_t.AddMemberTitle);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: FamilyMemberFormModel form })
        {
            Dispatcher.Dispatch(new AddAdminMemberAction(FamilyId, new AddFamilyMemberRequest(
                form.DisplayName,
                string.IsNullOrWhiteSpace(form.Email) ? null : form.Email!.Trim(),
                form.DateOfBirth,
                form.UseOverride ? form.WeightOverride : null,
                form.IsAdmin)));
        }
    }

    private async Task OpenEditMemberDialog(FamilyMemberDto member)
    {
        var initial = new FamilyMemberFormModel
        {
            DisplayName    = member.DisplayName,
            Email          = member.Email,
            DateOfBirth    = member.DateOfBirth,
            UseOverride    = member.WeightOverride is not null,
            WeightOverride = member.WeightOverride ?? 1.00m,
            IsAdmin        = member.IsAdmin
        };

        var parameters = new DialogParameters<FamilyMemberDialog>
        {
            { x => x.InitialValues, initial }
        };

        var dialog = await DialogService.ShowAsync<FamilyMemberDialog>(_t.EditMemberTitle, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: FamilyMemberFormModel form })
        {
            Dispatcher.Dispatch(new UpdateAdminMemberAction(FamilyId, member.Id,
                new UpdateFamilyMemberRequest(
                    form.DisplayName,
                    string.IsNullOrWhiteSpace(form.Email) ? null : form.Email!.Trim(),
                    form.DateOfBirth,
                    form.UseOverride ? form.WeightOverride : null,
                    form.IsAdmin)));
        }
    }

    private async Task ConfirmRemoveMember(FamilyMemberDto member)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.RemoveMember,
            _t.RemoveMemberConfirm,
            yesText: _t.Remove,
            cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new RemoveAdminMemberAction(FamilyId, member.Id));
    }
}
