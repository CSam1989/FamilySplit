@page "/admin"
@using FamilySplit.Client.Store.Admin
@using FamilySplit.Client.Store.Auth
@using FamilySplit.Client.Store.FamilyMembers
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IDispatcher Dispatcher
@inject IState<AdminState> State
@inject IState<FamilyMemberState> ProfileState
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject I18nText I18nText

<PageTitle>Admin — FamilySplit</PageTitle>

<RequireAdmin />

<MudText Typo="Typo.h5" Class="mb-1">@_t.AdminFamilies</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @_t.AdminFamiliesSubtitle
</MudText>

@if (State.Value.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearAdminErrorAction()))">
        @State.Value.ErrorMessage
    </MudAlert>
}

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.GroupAdd"
           OnClick="OpenCreateDialog"
           Class="mb-4">
    @_t.CreateFamily
</MudButton>

@if (State.Value.IsLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

@if (!State.Value.IsLoading && !State.Value.Families.Any())
{
    <MudPaper Elevation="0" Class="pa-6 d-flex flex-column align-center"
              Style="border: 1px dashed var(--mud-palette-divider);">
        <MudIcon Icon="@Icons.Material.Outlined.FamilyRestroom" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
        <MudText Typo="Typo.body1" Color="Color.Secondary">@_t.NoFamiliesYet</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@_t.CreateFirstFamily</MudText>
    </MudPaper>
}
else
{
    @foreach (var family in State.Value.Families)
    {
        <MudPaper Elevation="2" Class="pa-0 mb-2 overflow-hidden"
                  Style="cursor:pointer"
                  @onclick="@(() => Nav.NavigateTo($"/admin/families/{family.Id}"))">
            <MudStack Row="true" AlignItems="AlignItems.Stretch" Spacing="0">
                <div style="width:5px;background:var(--mud-palette-primary);flex-shrink:0" />
                <div style="flex:1;padding:12px 16px;min-width:0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom"
                                 Color="Color.Primary" Size="Size.Small" Style="flex-shrink:0" />
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @family.Name
                        </MudText>
                        @if (family.Members.Any(m => m.Id == ProfileState.Value.MyProfile?.Id))
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small"
                                     Icon="@Icons.Material.Filled.Home" Style="flex-shrink:0">
                                @_t.YourFamilyChip
                            </MudChip>
                        }
                        <MudSpacer />
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight"
                                 Color="Color.Secondary" Size="Size.Small" Style="flex-shrink:0" />
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.People"
                                     Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @family.Members.Count @_t.ColMembers
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday"
                                     Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @family.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                            </MudText>
                        </MudStack>
                    </MudStack>
                </div>
            </MudStack>
        </MudPaper>
    }
}

@code {
    private AppText _t = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _t = await I18nText.GetTextTableAsync<AppText>(this);
        Dispatcher.Dispatch(new LoadAdminFamiliesAction());
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateFamilyDialog>(_t.CreateFamilyTitle);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string name })
            Dispatcher.Dispatch(new CreateAdminFamilyAction(new CreateFamilyRequest(name)));
    }
}
