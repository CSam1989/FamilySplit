@page "/auth/return"
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>FamilySplit · Signing in…</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    @if (_error is null)
    {
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Class="mt-4">Completing sign-in…</MudText>
    }
    else
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-4" Href="/">Back to dashboard</MudButton>
    }
</MudContainer>

@code {
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        // The OAuth callback set an HttpOnly refresh cookie. Trade it for a JWT.
        var ok = await Auth.TryRefreshAsync();
        if (ok)
        {
            Nav.NavigateTo("/", forceLoad: true);
            return;
        }

        _error = "Sign-in session expired before we could establish the session. Please try again.";
    }
}
