@page "/auth/return"
@inject AuthService Auth
@inject NavigationManager Nav
@inject I18nText I18nText

<PageTitle>FamilySplit · Signing in…</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    @if (_error is null)
    {
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Class="mt-4">@_t.SignInCompleting</MudText>
    }
    else
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-4" Href="/">@_t.BackToDashboard</MudButton>
    }
</MudContainer>

@code {
    private AppText _t = new();
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _t = await I18nText.GetTextTableAsync<AppText>(this);

        // The OAuth callback set an HttpOnly refresh cookie. Trade it for a JWT.
        var ok = await Auth.TryRefreshAsync();
        if (ok)
        {
            // Use replace:true (in-SPA navigation) rather than forceLoad:true.
            // forceLoad restarts the entire WASM runtime, which boots a fresh AuthService
            // with no JWT and immediately fires another POST /auth/refresh with the same
            // cookie that was just rotated. That concurrent second call then triggers
            // theft-detection and revokes the user's entire session.
            // replace:true keeps the same WASM instance (same AuthService, same JWT already
            // in memory) and replaces the history entry so the back button can't re-enter
            // this callback page.
            Nav.NavigateTo("/", replace: true);
            return;
        }

        _error = _t.SignInExpired;
    }
}
