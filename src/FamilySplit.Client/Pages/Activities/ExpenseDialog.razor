@using FamilySplit.Client.Services
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Edit expense" : "Add expense")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField Label="Title" @bind-Value="_model.Title"
                          Required="true" RequiredError="Title is required."
                          MaxLength="200" Immediate="true" Class="mb-3" />

            <MudTextField Label="Description" @bind-Value="_model.Description"
                          Lines="2" MaxLength="500" Class="mb-3" />

            <MudStack Row="true" Spacing="3" Class="mb-3">
                <MudNumericField T="decimal" Label="Amount" @bind-Value="_model.TotalAmount"
                                 Required="true" RequiredError="Amount is required."
                                 Min="0.01m" Format="F2" Immediate="true"
                                 Style="flex:1" />
                <MudTextField Label="Currency" @bind-Value="_model.Currency"
                              MaxLength="3" Style="max-width:90px" />
            </MudStack>

            <MudDatePicker Label="Date" @bind-Date="_expenseDate"
                           Required="true" RequiredError="Date is required."
                           DateFormat="dd/MM/yyyy" Class="mb-1" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">
            @(IsEdit ? "Save" : "Add")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public string? InitialTitle { get; set; }
    [Parameter] public string? InitialDescription { get; set; }
    [Parameter] public decimal InitialAmount { get; set; }
    [Parameter] public string? InitialCurrency { get; set; }
    [Parameter] public DateOnly InitialDate { get; set; }

    private MudForm _form = default!;
    private readonly ExpenseFormModel _model = new();
    private DateTime? _expenseDate;

    protected override void OnParametersSet()
    {
        _model.Title       = InitialTitle ?? string.Empty;
        _model.Description = InitialDescription;
        _model.TotalAmount = InitialAmount;
        _model.Currency    = InitialCurrency ?? "EUR";
        _expenseDate       = InitialDate == default
            ? DateTime.Today
            : InitialDate.ToDateTime(TimeOnly.MinValue);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;
        _model.ExpenseDate = _expenseDate?.Date ?? DateTime.Today;
        MudDialog.Close(DialogResult.Ok(_model));
    }
}
