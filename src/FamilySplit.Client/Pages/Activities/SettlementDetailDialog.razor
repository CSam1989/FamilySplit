@using FamilySplit.Domain.Enums
@using FamilySplit.Client.Store.Settlements
@inject IDispatcher Dispatcher
@inject I18nText I18nText

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
            <MudText Typo="Typo.h6">@_t.TransferDetail</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (Settlement is null)
        {
            <MudText>Loading…</MudText>
        }
        else
        {
            var statusColor = Settlement.Status switch
            {
                SettlementStatus.Proposed  => Color.Warning,
                SettlementStatus.PayerSent => Color.Info,
                SettlementStatus.Completed => Color.Success,
                SettlementStatus.Cancelled => Color.Error,
                _                          => Color.Default
            };

            <MudGrid Spacing="2" Class="mb-4">
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.FromPayer</MudText>
                    <MudText Typo="Typo.body1"><strong>@Settlement.PayerFamilyName</strong></MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.ToReceiver</MudText>
                    <MudText Typo="Typo.body1"><strong>@Settlement.ReceiverFamilyName</strong></MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.ColAmount</MudText>
                    <MudText Typo="Typo.body1"><strong>@Settlement.Amount.ToString("F2") @Settlement.Currency</strong></MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.StatusLabel</MudText>
                    <MudChip T="string" Color="@statusColor" Size="Size.Small">
                        @(Settlement.Status == SettlementStatus.PayerSent ? _t.StatusSent : Settlement.Status.ToString())
                    </MudChip>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.ProposedAt</MudText>
                    <MudText Typo="Typo.body2">@Settlement.ProposedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudText>
                </MudItem>
                @if (Settlement.CompletedAt.HasValue)
                {
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.CompletedAt</MudText>
                        <MudText Typo="Typo.body2">@Settlement.CompletedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudText>
                    </MudItem>
                }
            </MudGrid>

            @if (Settlement.ApprovalSteps.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2">@_t.ApprovalHistory</MudText>
                <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mb-2">
                    @foreach (var step in Settlement.ApprovalSteps)
                    {
                        var stepIcon = step.StepType == StepType.PayerSent
                            ? Icons.Material.Filled.Send
                            : Icons.Material.Filled.CheckCircle;
                        var stepLabel = step.StepType == StepType.PayerSent
                            ? _t.PaymentSent
                            : _t.PaymentReceived;
                        <MudTimelineItem Icon="@stepIcon" Color="Color.Success" Size="Size.Small">
                            <ItemContent>
                                <MudText Typo="Typo.body2"><strong>@stepLabel</strong></MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    by @step.ApproverName
                                    @if (step.ActionedAt.HasValue)
                                    {
                                        @(" · ")@step.ActionedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                    }
                                </MudText>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No approval steps recorded yet.</MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        @if (Settlement is not null)
        {
            @if (Settlement.Status == SettlementStatus.Proposed && CallerFamilyId == Settlement.PayerFamilyId)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Send"
                           OnClick="OnMarkSent">
                    @_t.MarkSent
                </MudButton>
            }
            @if (Settlement.Status == SettlementStatus.PayerSent && CallerFamilyId == Settlement.ReceiverFamilyId)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="OnConfirmReceived">
                    @_t.MarkReceived
                </MudButton>
            }
        }
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public SettlementDetailDto? Settlement { get; set; }

    /// <summary>GroupId required to route the Fluxor action.</summary>
    [Parameter] public Guid GroupId { get; set; }

    /// <summary>ActivityId required to route the Fluxor action.</summary>
    [Parameter] public Guid ActivityId { get; set; }

    /// <summary>The caller's FamilyId — used to decide which action button to show.</summary>
    [Parameter] public Guid? CallerFamilyId { get; set; }

    private AppText _t = new();

    protected override async Task OnInitializedAsync()
    {
        _t = await I18nText.GetTextTableAsync<AppText>(this);
    }

    private void OnMarkSent()
    {
        Dispatcher.Dispatch(new ConfirmSentAction(GroupId, ActivityId, Settlement!.Id));
        MudDialog.Close();
    }

    private void OnConfirmReceived()
    {
        Dispatcher.Dispatch(new ConfirmReceivedAction(GroupId, ActivityId, Settlement!.Id));
        MudDialog.Close();
    }

    private void Close() => MudDialog.Close();
}
