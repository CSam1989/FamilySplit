@page "/groups/{GroupId:guid}/activities/{ActivityId:guid}"
@using FamilySplit.Client.Store.Groups
@using FamilySplit.Client.Store.Settlements
@using FamilySplit.Client.Store.FamilyMembers
@using FamilySplit.Client.Store.Family
@using FamilySplit.Domain.Enums
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IDispatcher Dispatcher
@inject IState<ActivityState> State
@inject IState<ExpenseState> ExpenseState
@inject IState<GroupState> GroupState
@inject IState<SettlementState> SettlementState
@inject IState<FamilyMemberState> ProfileState
@inject IState<FamilyState> FamilyState
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Activity — FamilySplit</PageTitle>

<RequireAuth />

@if (State.Value.IsLoading && State.Value.SelectedActivity is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    return;
}

@if (State.Value.ErrorMessage is not null && State.Value.SelectedActivity is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@State.Value.ErrorMessage</MudAlert>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo($"/groups/{GroupId}"))">
        Back to group
    </MudButton>
    return;
}

@{
    var activity = State.Value.SelectedActivity;
    if (activity is null) return;
    var isOpen   = activity.Status == ActivityStatus.Open;
    var isClosed = activity.Status == ActivityStatus.Closed;
    var isSettled = activity.Status == ActivityStatus.Settled;
    var statusColor = activity.Status switch
    {
        ActivityStatus.Open             => Color.Success,
        ActivityStatus.Closed           => Color.Default,
        ActivityStatus.AbsorbedByParent => Color.Warning,
        ActivityStatus.Settled          => Color.Info,
        _                               => Color.Default
    };
    var callerFamilyId = FamilyState.Value.MyFamily?.Id;
}

<MudBreadcrumbs Items="_crumbs" Class="mb-2" />

@if (State.Value.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearActivityErrorAction()))">
        @State.Value.ErrorMessage
    </MudAlert>
}

<!-- Header -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1" Spacing="2">
    <MudText Typo="Typo.h5">@activity.Name</MudText>
    <MudChip T="string" Color="@statusColor" Size="Size.Small">@activity.Status</MudChip>
    @if (activity.ParentActivityId is not null)
    {
        <MudChip T="string" Color="Color.Secondary" Size="Size.Small"
                 Icon="@Icons.Material.Filled.AccountTree">Sub-activity</MudChip>
    }
</MudStack>

@if (activity.Description is not null)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@activity.Description</MudText>
}

@if (activity.ClosedAt.HasValue)
{
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
        Closed @activity.ClosedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
    </MudText>
}

<!-- Action buttons -->
@if (isOpen)
{
    <MudStack Row="true" Class="mb-6" Spacing="2" Wrap="Wrap.Wrap">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Edit"
                   OnClick="OpenEditDialog">
            Edit
        </MudButton>
        @if (activity.ParentActivityId is null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CallSplit"
                       OnClick="OpenAddSubActivityDialog">
                Add sub-activity
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Lock"
                       OnClick="ConfirmClose">
                Close activity
            </MudButton>
        }
    </MudStack>
}

<!-- Participants -->
<MudText Typo="Typo.h6" Class="mb-3">
    Participants
    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-1">
        @activity.Participants.Count
    </MudChip>
</MudText>

@if (activity.Participants.Count == 0)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">No participants yet.</MudText>
}
else
{
    <MudTable Items="activity.Participants" Dense="true" Hover="true" Elevation="1" Class="mb-6">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Family</MudTh>
            <MudTh>Weight</MudTh>
            <MudTh>Tier</MudTh>
            @if (isOpen)
            {
                <MudTh></MudTh>
            }
        </HeaderContent>
        <RowTemplate Context="p">
            <MudTd DataLabel="Name">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Size="Size.Small" Color="Color.Primary">@p.DisplayName[0]</MudAvatar>
                    <MudText>@p.DisplayName</MudText>
                </MudStack>
            </MudTd>
            <MudTd DataLabel="Family">@p.FamilyName</MudTd>
            <MudTd DataLabel="Weight">@p.CurrentWeight.ToString("0.##")×</MudTd>
            <MudTd DataLabel="Tier">
                <WeightBadge Tier="p.CurrentTier" Weight="p.CurrentWeight" />
            </MudTd>
            @if (isOpen)
            {
                <MudTd>
                    <MudTooltip Text="Remove participant">
                        <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => ConfirmRemoveParticipant(p))" />
                    </MudTooltip>
                </MudTd>
            }
        </RowTemplate>
    </MudTable>
}

@if (isOpen)
{
    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="OpenAddParticipantDialog"
               Class="mb-6">
        Add participant
    </MudButton>
}

<!-- Expenses -->
<MudText Typo="Typo.h6" Class="mb-3">
    Expenses
    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-1">
        @ExpenseState.Value.Expenses.Count
    </MudChip>
    @if (ExpenseState.Value.Expenses.Count > 0)
    {
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-1">
            @ExpenseState.Value.Expenses.Sum(e => e.TotalAmount).ToString("F2") @(ExpenseState.Value.Expenses.FirstOrDefault()?.Currency ?? "EUR")
        </MudChip>
    }
</MudText>

@if (ExpenseState.Value.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearExpenseErrorAction()))">
        @ExpenseState.Value.ErrorMessage
    </MudAlert>
}

@if (ExpenseState.Value.IsLoading && ExpenseState.Value.Expenses.Count == 0)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (ExpenseState.Value.Expenses.Count == 0)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">No expenses yet.</MudText>
}
else
{
    <MudTable Items="ExpenseState.Value.Expenses" Dense="true" Hover="true" Elevation="1" Class="mb-4">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Date</MudTh>
            <MudTh>Paid by</MudTh>
            <MudTh Style="text-align:right">Amount</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate Context="e">
            <MudTd DataLabel="Title">
                <MudText Typo="Typo.body2">@e.Title</MudText>
                @if (e.Description is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@e.Description</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Date">
                <MudText Typo="Typo.body2">@e.ExpenseDate.ToString("dd MMM yyyy")</MudText>
            </MudTd>
            <MudTd DataLabel="Paid by">
                <MudText Typo="Typo.body2">@e.PaidByName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@e.PaidByFamilyName</MudText>
            </MudTd>
            <MudTd DataLabel="Amount" Style="text-align:right">
                <MudText Typo="Typo.body2"><strong>@e.TotalAmount.ToString("F2") @e.Currency</strong></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@e.ParticipantCount participants</MudText>
            </MudTd>
            <MudTd Style="text-align:right">
                <MudStack Row="true" Spacing="0" Justify="Justify.FlexEnd">
                    <MudTooltip Text="View breakdown">
                        <MudIconButton Icon="@Icons.Material.Filled.BarChart"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenExpenseDetail(e.Id))" />
                    </MudTooltip>
                    @if (activity.Status != ActivityStatus.Settled && e.Status != ExpenseStatus.Locked)
                    {
                        <MudTooltip Text="Edit">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenEditExpenseDialog(e))" />
                        </MudTooltip>
                        <MudTooltip Text="Delete">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => ConfirmDeleteExpense(e))" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@if (activity.Status != ActivityStatus.Settled)
{
    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.AddShoppingCart"
               OnClick="OpenAddExpenseDialog"
               Class="mb-6">
        Add expense
    </MudButton>
}

<!-- Sub-activities (top-level only) -->
@if (activity.ParentActivityId is null)
{
    <MudText Typo="Typo.h6" Class="mb-3">
        Sub-activities
        <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-1">
            @activity.SubActivities.Count
        </MudChip>
    </MudText>

    @if (activity.SubActivities.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">No sub-activities.</MudText>
    }
    else
    {
        @foreach (var sub in activity.SubActivities)
        {
            var subStatusColor = sub.Status switch
            {
                ActivityStatus.Open             => Color.Success,
                ActivityStatus.AbsorbedByParent => Color.Warning,
                ActivityStatus.Closed           => Color.Default,
                ActivityStatus.Settled          => Color.Info,
                _                               => Color.Default
            };

            <MudPaper Elevation="1" Class="pa-3 mb-3 d-flex flex-row align-center gap-3"
                      Style="cursor:pointer"
                      @onclick="@(() => Nav.NavigateTo($"/groups/{GroupId}/activities/{sub.Id}"))">
                <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Secondary" />
                <div style="flex:1">
                    <MudText Typo="Typo.subtitle2">@sub.Name</MudText>
                    @if (sub.Description is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@sub.Description</MudText>
                    }
                </div>
                <MudChip T="string" Color="@subStatusColor" Size="Size.Small">@sub.Status</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @sub.ParticipantCount participants
                </MudText>
            </MudPaper>
        }
    }
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- Settlements (visible on Closed or Settled activities, top-level only)     -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if ((isClosed || isSettled) && activity.ParentActivityId is null)
{
    <MudDivider Class="my-6" />

    <MudText Typo="Typo.h6" Class="mb-3">
        Settlements
        @if (isSettled)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-1">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" />
                Settled
            </MudChip>
        }
    </MudText>

    @if (SettlementState.Value.ErrorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
                  CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearSettlementErrorAction()))">
            @SettlementState.Value.ErrorMessage
        </MudAlert>
    }

    <!-- Per-family balance summary -->
    @if (SettlementState.Value.Balances.Count > 0)
    {
        <MudText Typo="Typo.subtitle2" Class="mb-2">Balance summary</MudText>
        <MudGrid Spacing="2" Class="mb-4">
            @foreach (var b in SettlementState.Value.Balances)
            {
                var balColor = b.Balance > 0 ? Color.Success : b.Balance < 0 ? Color.Error : Color.Default;
                var balIcon  = b.Balance > 0 ? Icons.Material.Filled.TrendingUp
                             : b.Balance < 0 ? Icons.Material.Filled.TrendingDown
                             : Icons.Material.Filled.HorizontalRule;
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@balIcon" Color="@balColor" />
                            <div style="flex:1">
                                <MudText Typo="Typo.subtitle2">@b.FamilyName</MudText>
                                <MudText Typo="Typo.body2" Color="@balColor">
                                    @(b.Balance >= 0 ? "+" : "")@b.Balance.ToString("F2") @b.Currency
                                </MudText>
                            </div>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

    @if (SettlementState.Value.IsLoading || SettlementState.Value.IsGenerating)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else if (isClosed && SettlementState.Value.Settlements.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            No settlements generated yet. Generate them to calculate what each family owes.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Calculate"
                   OnClick="GenerateSettlements"
                   Disabled="SettlementState.Value.IsGenerating"
                   Class="mb-4">
            Generate settlements
        </MudButton>
    }
    else if (SettlementState.Value.Settlements.Count == 0 && isSettled)
    {
        <MudAlert Severity="Severity.Success">All balances were already even — no transfers needed.</MudAlert>
    }
    else if (SettlementState.Value.Settlements.Count > 0)
    {
        <MudTable Items="SettlementState.Value.Settlements" Dense="true" Hover="true" Elevation="1" Class="mb-4">
            <HeaderContent>
                <MudTh>From</MudTh>
                <MudTh>To</MudTh>
                <MudTh Style="text-align:right">Amount</MudTh>
                <MudTh>Status</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate Context="s">
                @{
                    var sColor = s.Status switch
                    {
                        SettlementStatus.Proposed  => Color.Warning,
                        SettlementStatus.PayerSent => Color.Info,
                        SettlementStatus.Completed => Color.Success,
                        SettlementStatus.Cancelled => Color.Error,
                        _                          => Color.Default
                    };
                    var isCallerPayer    = callerFamilyId == s.PayerFamilyId;
                    var isCallerReceiver = callerFamilyId == s.ReceiverFamilyId;
                }
                <MudTd DataLabel="From">
                    <MudText Typo="Typo.body2">@s.PayerFamilyName</MudText>
                </MudTd>
                <MudTd DataLabel="To">
                    <MudText Typo="Typo.body2">@s.ReceiverFamilyName</MudText>
                </MudTd>
                <MudTd DataLabel="Amount" Style="text-align:right">
                    <strong>@s.Amount.ToString("F2") @s.Currency</strong>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@sColor" Size="Size.Small">@s.Status</MudChip>
                </MudTd>
                <MudTd Style="text-align:right">
                    <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                        @if (s.Status == SettlementStatus.Proposed && isCallerPayer)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                       OnClick="@(() => ConfirmSent(s))">
                                Mark sent
                            </MudButton>
                        }
                        @if (s.Status == SettlementStatus.PayerSent && isCallerReceiver)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                       OnClick="@(() => ConfirmReceived(s))">
                                Confirm received
                            </MudButton>
                        }
                        <MudTooltip Text="View detail">
                            <MudIconButton Icon="@Icons.Material.Filled.Info"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenSettlementDetail(s.Id))" />
                        </MudTooltip>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    [Parameter] public Guid GroupId { get; set; }
    [Parameter] public Guid ActivityId { get; set; }

    private List<BreadcrumbItem> _crumbs = [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        BuildCrumbs();
        Dispatcher.Dispatch(new LoadActivityDetailAction(GroupId, ActivityId));
        Dispatcher.Dispatch(new LoadExpensesAction(GroupId, ActivityId));
        // Ensure the caller's family is loaded (needed for settlement permission checks).
        if (FamilyState.Value.MyFamily is null)
            Dispatcher.Dispatch(new LoadMyFamilyAction());
        LoadSettlementsIfNeeded();
    }

    protected override void OnParametersSet()
    {
        if (State.Value.SelectedActivity?.Id != ActivityId)
        {
            BuildCrumbs();
            Dispatcher.Dispatch(new LoadActivityDetailAction(GroupId, ActivityId));
            Dispatcher.Dispatch(new LoadExpensesAction(GroupId, ActivityId));
            Dispatcher.Dispatch(new ClearSettlementsAction());
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        // Once the activity loads, we know if it's closed/settled; load settlements then.
        var activity = State.Value.SelectedActivity;
        if (activity is not null
            && activity.ParentActivityId is null
            && (activity.Status == ActivityStatus.Closed || activity.Status == ActivityStatus.Settled)
            && SettlementState.Value.Settlements.Count == 0
            && !SettlementState.Value.IsLoading
            && !SettlementState.Value.IsGenerating)
        {
            LoadSettlementsIfNeeded();
        }
    }

    private void LoadSettlementsIfNeeded()
    {
        var activity = State.Value.SelectedActivity;
        if (activity is null) return;
        if (activity.ParentActivityId is not null) return;
        if (activity.Status != ActivityStatus.Closed && activity.Status != ActivityStatus.Settled) return;

        Dispatcher.Dispatch(new LoadSettlementsAction(GroupId, ActivityId));
        Dispatcher.Dispatch(new LoadBalancesAction(GroupId, ActivityId));
    }

    private void BuildCrumbs()
    {
        var groupName = GroupState.Value.SelectedGroup?.Name ?? "Group";
        _crumbs =
        [
            new BreadcrumbItem("Groups", href: "/groups"),
            new BreadcrumbItem(groupName, href: $"/groups/{GroupId}"),
            new BreadcrumbItem("Activity", href: null, disabled: true),
        ];
    }

    // ── Edit ──────────────────────────────────────────────────────────────────

    private async Task OpenEditDialog()
    {
        var activity = State.Value.SelectedActivity!;
        var dialog = await DialogService.ShowAsync<EditActivityDialog>("Edit activity",
            new DialogParameters<EditActivityDialog>
            {
                { x => x.InitialName, activity.Name },
                { x => x.InitialDescription, activity.Description }
            });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ActivityFormModel form })
        {
            Dispatcher.Dispatch(new UpdateActivityAction(GroupId, ActivityId,
                new UpdateActivityRequest(form.Name, form.Description)));
        }
    }

    // ── Add sub-activity ──────────────────────────────────────────────────────

    private async Task OpenAddSubActivityDialog()
    {
        var parameters = new DialogParameters<CreateActivityDialog>
        {
            { x => x.IsSubActivity, true }
        };
        var dialog = await DialogService.ShowAsync<CreateActivityDialog>("New sub-activity", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ActivityFormModel form })
        {
            Dispatcher.Dispatch(new CreateSubActivityAction(GroupId, ActivityId,
                new CreateActivityRequest(form.Name, form.Description)));
        }
    }

    // ── Close ─────────────────────────────────────────────────────────────────

    private async Task ConfirmClose()
    {
        var activity = State.Value.SelectedActivity!;
        var hasOpenSubs = activity.SubActivities.Any(s => s.Status == ActivityStatus.Open);
        var message = hasOpenSubs
            ? $"Close \"{activity.Name}\"? {activity.SubActivities.Count(s => s.Status == ActivityStatus.Open)} open sub-activit{(activity.SubActivities.Count(s => s.Status == ActivityStatus.Open) == 1 ? "y" : "ies")} will be absorbed."
            : $"Close \"{activity.Name}\"? This cannot be undone.";

        bool? confirmed = await DialogService.ShowMessageBox(
            "Close activity", message, yesText: "Close", cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new CloseActivityAction(GroupId, ActivityId));
    }

    // ── Add participant ───────────────────────────────────────────────────────

    private async Task OpenAddParticipantDialog()
    {
        var activity = State.Value.SelectedActivity!;
        var existingIds = activity.Participants.Select(p => p.FamilyMemberId).ToHashSet();

        var groupDetail = GroupState.Value.SelectedGroup;
        if (groupDetail is null) return;

        var available = groupDetail.Families
            .SelectMany(f => f.Members.Select(m => (m, f.FamilyName)))
            .Where(t => !existingIds.Contains(t.m.Id))
            .ToList();

        if (available.Count == 0)
        {
            await DialogService.ShowMessageBox("Add participant",
                "All group members are already participating in this activity.", yesText: "OK");
            return;
        }

        var parameters = new DialogParameters<AddParticipantDialog>
        {
            { x => x.Available, available }
        };
        var dialog = await DialogService.ShowAsync<AddParticipantDialog>("Add participant", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: Guid memberId })
        {
            Dispatcher.Dispatch(new AddParticipantAction(GroupId, ActivityId,
                new AddParticipantRequest(memberId)));
        }
    }

    // ── Remove participant ────────────────────────────────────────────────────

    private async Task ConfirmRemoveParticipant(ActivityParticipantDto p)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Remove participant",
            $"Remove {p.DisplayName} from this activity?",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new RemoveParticipantAction(GroupId, ActivityId, p.FamilyMemberId));
    }

    // ── Expenses ──────────────────────────────────────────────────────────────

    private async Task OpenAddExpenseDialog()
    {
        var dialog = await DialogService.ShowAsync<ExpenseDialog>("Add expense",
            new DialogParameters<ExpenseDialog> { { x => x.IsEdit, false } });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ExpenseFormModel form })
        {
            Dispatcher.Dispatch(new CreateExpenseAction(GroupId, ActivityId,
                new CreateExpenseRequest(
                    form.Title,
                    form.Description,
                    form.TotalAmount,
                    form.Currency,
                    DateOnly.FromDateTime(form.ExpenseDate),
                    null)));
        }
    }

    private async Task OpenEditExpenseDialog(ExpenseSummaryDto expense)
    {
        var dialog = await DialogService.ShowAsync<ExpenseDialog>("Edit expense",
            new DialogParameters<ExpenseDialog>
            {
                { x => x.IsEdit,             true },
                { x => x.InitialTitle,       expense.Title },
                { x => x.InitialDescription, expense.Description },
                { x => x.InitialAmount,      expense.TotalAmount },
                { x => x.InitialCurrency,    expense.Currency },
                { x => x.InitialDate,        expense.ExpenseDate },
            });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ExpenseFormModel form })
        {
            Dispatcher.Dispatch(new UpdateExpenseAction(GroupId, ActivityId, expense.Id,
                new UpdateExpenseRequest(
                    form.Title,
                    form.Description,
                    form.TotalAmount,
                    form.Currency,
                    DateOnly.FromDateTime(form.ExpenseDate),
                    null)));
        }
    }

    private async Task OpenExpenseDetail(Guid expenseId)
    {
        Dispatcher.Dispatch(new LoadExpenseDetailAction(GroupId, ActivityId, expenseId));

        for (var i = 0; i < 30; i++)
        {
            if (ExpenseState.Value.SelectedExpense?.Id == expenseId) break;
            await Task.Delay(100);
        }

        var expense = ExpenseState.Value.SelectedExpense;
        if (expense is null) return;

        await DialogService.ShowAsync<ExpenseDetailDialog>("Expense breakdown",
            new DialogParameters<ExpenseDetailDialog>
            {
                { x => x.Expense, expense }
            });
    }

    private async Task ConfirmDeleteExpense(ExpenseSummaryDto expense)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Delete expense",
            $"Delete \"{expense.Title}\" ({expense.TotalAmount:F2} {expense.Currency})? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new DeleteExpenseAction(GroupId, ActivityId, expense.Id));
    }

    // ── Settlements ───────────────────────────────────────────────────────────

    private async Task GenerateSettlements()
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Generate settlements",
            "Calculate and propose the optimal payment transfers for this activity? This will use the current expense data.",
            yesText: "Generate", cancelText: "Cancel");

        if (confirmed == true)
        {
            Dispatcher.Dispatch(new GenerateSettlementsAction(GroupId, ActivityId));
            Dispatcher.Dispatch(new LoadBalancesAction(GroupId, ActivityId));
        }
    }

    private async Task ConfirmSent(SettlementSummaryDto settlement)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Confirm payment sent",
            $"Confirm that {settlement.PayerFamilyName} has sent {settlement.Amount:F2} {settlement.Currency} to {settlement.ReceiverFamilyName}?",
            yesText: "Confirm", cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new ConfirmSentAction(GroupId, ActivityId, settlement.Id));
    }

    private async Task ConfirmReceived(SettlementSummaryDto settlement)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Confirm payment received",
            $"Confirm that {settlement.ReceiverFamilyName} has received {settlement.Amount:F2} {settlement.Currency} from {settlement.PayerFamilyName}?",
            yesText: "Confirm", cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new ConfirmReceivedAction(GroupId, ActivityId, settlement.Id));
    }

    private async Task OpenSettlementDetail(Guid settlementId)
    {
        Dispatcher.Dispatch(new LoadSettlementDetailAction(GroupId, ActivityId, settlementId));

        for (var i = 0; i < 30; i++)
        {
            if (SettlementState.Value.SelectedSettlement?.Id == settlementId) break;
            await Task.Delay(100);
        }

        var settlement = SettlementState.Value.SelectedSettlement;
        if (settlement is null) return;

        await DialogService.ShowAsync<SettlementDetailDialog>("Settlement detail",
            new DialogParameters<SettlementDetailDialog>
            {
                { x => x.Settlement, settlement }
            });
    }
}
