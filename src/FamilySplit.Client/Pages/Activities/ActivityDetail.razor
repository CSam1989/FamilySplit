    private async Task ConfirmClose()
    {
        var activity    = State.Value.SelectedActivity!;
        var openSubCount = activity.SubActivities.Count(s => s.Status == ActivityStatus.Open);
        var message = openSubCount > 0
            ? $"Close \"{activity.Name}\"? {openSubCount} open sub-activit{(openSubCount == 1 ? "y" : "ies")} will be absorbed."
            : $"Close \"{activity.Name}\"? This cannot be undone.";

        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.CloseActivity, message, yesText: _t.CloseActivityYes, cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new CloseActivityAction(GroupId, ActivityId));
    }

    private async Task OpenAddParticipantDialog()
    {
        var activity    = State.Value.SelectedActivity!;
        var existingIds = activity.Participants.Select(p => p.FamilyMemberId).ToHashSet();
        var groupDetail = GroupState.Value.SelectedGroup;
        if (groupDetail is null) return;

        var available = groupDetail.Families
            .SelectMany(f => f.Members.Select(m => (m, f.FamilyName)))
            .Where(t => !existingIds.Contains(t.m.Id))
            .ToList();

        if (available.Count == 0)
        {
            await DialogService.ShowMessageBoxAsync(_t.AddParticipant,
                _t.AllMembersParticipating, yesText: "OK");
            return;
        }

        var dialog = await DialogService.ShowAsync<AddParticipantDialog>(_t.AddParticipant,
            new DialogParameters<AddParticipantDialog> { { x => x.Available, available } });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: Guid memberId })
            Dispatcher.Dispatch(new AddParticipantAction(GroupId, ActivityId,
                new AddParticipantRequest(memberId)));
    }

