@using FamilySplit.Client.Pages.Activities
@inject MudBlazor.IDialogService DialogService
@inject I18nText I18nText

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.EventNote" Class="mr-2" />
            @(IsSubActivity ? _t.SubActivity : _t.NewActivity)
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_model.Name"
                          Label="@_t.ActivityName"
                          Required="true"
                          RequiredError="@_t.ActivityNameRequired"
                          MaxLength="100"
                          Counter="100"
                          Class="mb-3" />
            <MudTextField @bind-Value="_model.Description"
                          Label="@_t.DescriptionOptional"
                          MaxLength="500"
                          Counter="500"
                          Lines="3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@_t.Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!_isValid)">
            @_t.Add
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public bool IsSubActivity { get; set; }

    private MudForm _form = default!;
    private bool _isValid;
    private readonly ActivityFormModel _model = new();
    private AppText _t = new();

    protected override async Task OnInitializedAsync()
    {
        _t = await I18nText.GetTextTableAsync<AppText>(this);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        MudDialog.Close(DialogResult.Ok(_model));
    }
}
