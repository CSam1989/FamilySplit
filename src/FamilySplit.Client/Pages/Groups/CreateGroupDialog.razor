@inject IDialogService DialogService
@inject I18nText I18nText

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@_t.CreateGroup</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string"
                          Label="@_t.GroupName"
                          @bind-Value="_name"
                          Required="true"
                          RequiredError="@_t.GroupNameRequired"
                          MaxLength="100"
                          Counter="100"
                          Immediate="true"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="@_t.DescriptionOptional"
                          @bind-Value="_description"
                          MaxLength="500"
                          Counter="500"
                          Lines="3"
                          Immediate="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@_t.Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!_isValid)">
            @_t.Add
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm  _form        = default!;
    private bool     _isValid;
    private string   _name        = "";
    private string?  _description;
    private AppText  _t           = new();

    protected override async Task OnInitializedAsync()
    {
        _t = await I18nText.GetTextTableAsync<AppText>(this);
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        MudDialog.Close(DialogResult.Ok(new CreateGroupFormModel(_name, _description)));
    }
}
