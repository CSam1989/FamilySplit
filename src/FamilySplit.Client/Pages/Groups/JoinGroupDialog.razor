@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Join group</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Enter the 8-character invite code shared by the group admin.
        </MudText>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string"
                          Label="Invite code"
                          @bind-Value="_inviteCode"
                          Required="true"
                          RequiredError="Invite code is required."
                          MaxLength="8"
                          Immediate="true"
                          Placeholder="e.g. AB3FGH7K"
                          Validation="@(new Func<string, IEnumerable<string>>(ValidateInviteCode))" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!_isValid)">
            Join
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm _form       = default!;
    private bool    _isValid;
    private string  _inviteCode = "";

    private static IEnumerable<string> ValidateInviteCode(string code)
    {
        if (string.IsNullOrWhiteSpace(code)) yield break; // Required handles the empty case
        if (code.Trim().Length != 8) yield return "Invite code must be exactly 8 characters.";
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        MudDialog.Close(DialogResult.Ok(_inviteCode.Trim().ToUpperInvariant()));
    }

    private void Cancel() => MudDialog.Cancel();
}
