@page "/groups/{GroupId:guid}"
@using FamilySplit.Client.Store.Groups
@using FamilySplit.Client.Store.Activities
@using FamilySplit.Client.Store.FamilyMembers
@using FamilySplit.Client.Store.Auth
@using FamilySplit.Client.Store.Family
@using FamilySplit.Client.Store.Settlements
@using FamilySplit.Client.Services
@using FamilySplit.Domain.Enums
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IDispatcher Dispatcher
@inject IState<GroupState> State
@inject IState<ActivityState> ActivityState
@inject IState<FamilyMemberState> ProfileState
@inject IState<AuthState> AuthState
@inject IState<FamilyState> FamilyState
@inject IState<SettlementState> SettlementState
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject I18nText I18nText

<PageTitle>Group — FamilySplit</PageTitle>

<RequireAuth />

@if (State.Value.IsLoading && State.Value.SelectedGroup is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    return;
}

@if (State.Value.ErrorMessage is not null && State.Value.SelectedGroup is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@State.Value.ErrorMessage</MudAlert>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/groups"))">@_t.BackToGroups</MudButton>
    return;
}

@{
    var group = State.Value.SelectedGroup;
    if (group is null) return;
    var isAdmin = group.CallerFamilyRole == MemberRole.Admin;

    var openCount     = ActivityState.Value.Activities.Count(a => a.Status == ActivityStatus.Open);
    var closedCount   = ActivityState.Value.Activities.Count(a => a.Status == ActivityStatus.Closed);
    var settledCount  = ActivityState.Value.Activities.Count(a => a.Status == ActivityStatus.Settled);
    var totalCount    = ActivityState.Value.Activities.Count;
    var totalMembers  = group.Families.Sum(f => f.Members.Count);

    var callerFamilyId    = FamilyState.Value.MyFamily?.Id;
    var pendingCount      = SettlementState.Value.GroupSettlements.Count;
}

<MudBreadcrumbs Items="_crumbs" Class="mb-2" />

<!-- ── Header ──────────────────────────────────────────────────────────────── -->
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1" Wrap="Wrap.Wrap">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudText Typo="Typo.h5">@group.Name</MudText>
        @if (isAdmin)
        {
            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@_t.FamilyAdminChip</MudChip>
        }
    </MudStack>

    <!-- Action buttons in header -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
        @if (isAdmin)
        {
            <MudTooltip Text="@_t.EditGroup">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Medium"
                               Color="Color.Default"
                               OnClick="OpenEditDialog" />
            </MudTooltip>
        }
        @if (IsCallerFamilyAdmin)
        {
            <MudTooltip Text="@_t.LeaveGroup">
                <MudIconButton Icon="@Icons.Material.Filled.ExitToApp"
                               Size="Size.Medium"
                               Color="Color.Error"
                               OnClick="ConfirmLeave" />
            </MudTooltip>
        }
        @if (AuthState.Value.IsGlobalAdmin)
        {
            <MudTooltip Text="@_t.DeleteGroup">
                <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                               Size="Size.Medium"
                               Color="Color.Error"
                               OnClick="ConfirmDelete" />
            </MudTooltip>
        }
    </MudStack>
</MudStack>

@if (group.Description is not null)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@group.Description</MudText>
}

@if (State.Value.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearGroupErrorAction()))">
        @State.Value.ErrorMessage
    </MudAlert>
}

<!-- ── Summary stat cards ─────────────────────────────────────────────────── -->
<MudGrid Spacing="3" Class="mb-5">
    <MudItem xs="6" sm="3">
        <MudPaper Elevation="1" Class="pa-4 d-flex flex-column align-center" Style="text-align:center">
            <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Primary" Class="mb-1" />
            <MudText Typo="Typo.h5"><strong>@totalCount</strong></MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.Activities</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Elevation="1" Class="pa-4 d-flex flex-column align-center" Style="text-align:center">
            <MudIcon Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" Class="mb-1" />
            <MudText Typo="Typo.h5"><strong>@openCount</strong></MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.Open</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Elevation="1" Class="pa-4 d-flex flex-column align-center" Style="text-align:center">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Info" Class="mb-1" />
            <MudText Typo="Typo.h5"><strong>@settledCount</strong></MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.Settled</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Elevation="1" Class="pa-4 d-flex flex-column align-center" Style="text-align:center">
            <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom" Color="Color.Secondary" Class="mb-1" />
            <MudText Typo="Typo.h5"><strong>@group.Families.Count</strong></MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Families · @totalMembers @_t.Members</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- ── Activities (primary) ───────────────────────────────────────────────── -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
    <MudText Typo="Typo.h6">@_t.Activities</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Medium"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateActivityDialog">
        @_t.NewActivity
    </MudButton>
</MudStack>

@if (ActivityState.Value.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearActivityErrorAction()))">
        @ActivityState.Value.ErrorMessage
    </MudAlert>
}

@if (ActivityState.Value.IsLoading && !ActivityState.Value.Activities.Any())
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
}
else if (!ActivityState.Value.Activities.Any())
{
    <MudPaper Elevation="0" Class="pa-6 d-flex flex-column align-center mb-6"
              Style="border: 1px dashed var(--mud-palette-divider);">
        <MudIcon Icon="@Icons.Material.Outlined.EventNote" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">@_t.NoActivitiesYet</MudText>
    </MudPaper>
}
else
{
    @foreach (var activity in ActivityState.Value.Activities)
    {
        var (statusColor, statusIcon, stripeColor) = activity.Status switch
        {
            ActivityStatus.Open    => (Color.Success, Icons.Material.Filled.LockOpen,   "var(--mud-palette-success)"),
            ActivityStatus.Closed  => (Color.Warning, Icons.Material.Filled.Lock,        "var(--mud-palette-warning)"),
            ActivityStatus.Settled => (Color.Info,    Icons.Material.Filled.CheckCircle, "var(--mud-palette-info)"),
            _                      => (Color.Default, Icons.Material.Filled.Circle,      "var(--mud-palette-divider)")
        };

        <MudPaper Elevation="2" Class="pa-0 mb-3 overflow-hidden"
                  Style="cursor:pointer"
                  @onclick="@(() => Nav.NavigateTo($"/groups/{GroupId}/activities/{activity.Id}"))">
            <MudStack Row="true" AlignItems="AlignItems.Stretch" Spacing="0">

                <!-- Status stripe -->
                <div style="width:5px; background:@stripeColor; flex-shrink:0;" />

                <!-- Main content -->
                <div style="flex:1; padding: 14px 16px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600">@activity.Name</MudText>
                        <MudChip T="string" Color="@statusColor" Size="Size.Small" Icon="@statusIcon">@activity.Status</MudChip>
                        <MudSpacer />
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Secondary" Size="Size.Small" />
                    </MudStack>

                    @if (activity.Description is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">@activity.Description</MudText>
                    }

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@activity.ParticipantCount @_t.ParticipantsCount</MudText>
                        </MudStack>

                        @if (activity.SubActivityCount > 0)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @activity.SubActivityCount @(_t.SubActivityCount + (activity.SubActivityCount == 1 ? _t.SubActivitySingular : _t.SubActivityPlural))
                                </MudText>
                            </MudStack>
                        }

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @activity.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                            </MudText>
                        </MudStack>

                        @if (activity.ClosedAt.HasValue)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @_t.ClosedAt @activity.ClosedAt.Value.ToLocalTime().ToString("dd MMM yyyy")
                                </MudText>
                            </MudStack>
                        }
                    </MudStack>
                </div>
            </MudStack>
        </MudPaper>
    }
}

<!-- ── Settlements ─────────────────────────────────────────────────────────── -->
<MudDivider Class="mt-4 mb-4" />

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Warning" Size="Size.Small" />
    <MudText Typo="Typo.h6">@_t.Settlements</MudText>
    @if (pendingCount > 0)
    {
        <MudChip T="string" Color="Color.Warning" Size="Size.Small">@pendingCount @_t.PendingChip</MudChip>
    }
</MudStack>

@if (SettlementState.Value.IsLoadingGroupSettlements)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mb-3" />
}
else if (!SettlementState.Value.GroupSettlements.Any())
{
    <MudPaper Elevation="0" Class="pa-5 d-flex flex-column align-center mb-4"
              Style="border: 1px dashed var(--mud-palette-divider);">
        <MudIcon Icon="@Icons.Material.Outlined.AccountBalance" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">@_t.NoPendingSettlementsGroup</MudText>
    </MudPaper>
}
else
{
    @foreach (var activityGroup in SettlementState.Value.GroupSettlements
        .GroupBy(s => new { s.ActivityId, s.ActivityName })
        .OrderBy(g => g.Key.ActivityName))
    {
        <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" Style="vertical-align:middle;margin-right:4px" />
            @activityGroup.Key.ActivityName
        </MudText>

        @foreach (var s in activityGroup)
        {
            var isCallerPayer    = callerFamilyId == s.PayerFamilyId;
            var isCallerReceiver = callerFamilyId == s.ReceiverFamilyId;
            var payerStyle       = isCallerPayer    ? "font-weight:600" : "font-weight:400";
            var receiverStyle    = isCallerReceiver ? "font-weight:600" : "font-weight:400";
            var (chipColor, chipIcon) = s.Status switch
            {
                SettlementStatus.Proposed  => (Color.Warning, Icons.Material.Filled.Pending),
                SettlementStatus.PayerSent => (Color.Info,    Icons.Material.Filled.Send),
                _                          => (Color.Default, Icons.Material.Filled.Circle),
            };

            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">

                    <!-- Payer → Receiver arrow -->
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex:1;min-width:0">
                        <MudAvatar Size="Size.Small" Color="@(isCallerPayer ? Color.Primary : Color.Default)">
                            @s.PayerFamilyName[0]
                        </MudAvatar>
                        <MudText Typo="Typo.body2" Style="@payerStyle">@s.PayerFamilyName</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Secondary" />
                        <MudAvatar Size="Size.Small" Color="@(isCallerReceiver ? Color.Success : Color.Default)">
                            @s.ReceiverFamilyName[0]
                        </MudAvatar>
                        <MudText Typo="Typo.body2" Style="@receiverStyle">@s.ReceiverFamilyName</MudText>
                    </MudStack>

                    <!-- Amount -->
                    <MudText Typo="Typo.subtitle2" Style="font-weight:700">
                        @FormatSettlementAmount(s.Amount, s.Currency)
                    </MudText>

                    <!-- Status chip -->
                    <MudChip T="string" Color="@chipColor" Size="Size.Small" Icon="@chipIcon">
                        @(s.Status == SettlementStatus.PayerSent ? _t.StatusSent : s.Status.ToString())
                    </MudChip>

                    <!-- Action buttons -->
                    @if (s.Status == SettlementStatus.Proposed && isCallerPayer)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   OnClick="@(() => ConfirmGroupSettlementSent(s))">
                            @_t.MarkSent
                        </MudButton>
                    }
                    @if (s.Status == SettlementStatus.PayerSent && isCallerReceiver)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="@(() => ConfirmGroupSettlementReceived(s))">
                            @_t.MarkReceived
                        </MudButton>
                    }

                    <!-- View activity link -->
                    <MudTooltip Text="@_t.ViewActivity">
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                       Size="Size.Medium"
                                       Color="Color.Default"
                                       Href="@($"/groups/{GroupId}/activities/{s.ActivityId}")" />
                    </MudTooltip>

                </MudStack>
            </MudPaper>
        }
    }
}

<!-- ── Families (secondary, collapsible) ──────────────────────────────────── -->
<MudDivider Class="mt-4 mb-4" />

<MudExpansionPanels Elevation="0">
    <MudExpansionPanel>
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom" Color="Color.Secondary" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                    @_t.FamiliesAndMembers
                </MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Default">@group.Families.Count families · @totalMembers @_t.Members</MudChip>
                @if (AuthState.Value.IsGlobalAdmin)
                {
                    <span @onclick:stopPropagation="true">
                        <MudTooltip Text="@_t.AddFamily">
                            <MudIconButton Icon="@Icons.Material.Filled.GroupAdd"
                                           Size="Size.Medium"
                                           Color="Color.Primary"
                                           OnClick="OpenAddFamilyDialog" />
                        </MudTooltip>
                    </span>
                }
            </MudStack>
        </TitleContent>
        <ChildContent>
            <!-- Invite code row -->
            <MudPaper Elevation="0" Class="pa-3 mb-4 d-flex flex-row align-center gap-3"
                      Style="border:1px solid var(--mud-palette-divider); width:fit-content">
                <MudIcon Icon="@Icons.Material.Filled.VpnKey" Color="Color.Primary" Size="Size.Small" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_t.InviteCode</MudText>
                    <MudText Typo="Typo.subtitle2" Style="letter-spacing:0.2em">@group.InviteCode</MudText>
                </div>
                <MudTooltip Text="@_t.CopyInviteCode">
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                   Size="Size.Medium"
                                   OnClick="CopyInviteCode" />
                </MudTooltip>
                @if (isAdmin)
                {
                    <MudTooltip Text="@_t.RegenerateInviteCode">
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Medium"
                                       Color="Color.Warning"
                                       OnClick="ConfirmRegenerate" />
                    </MudTooltip>
                }
            </MudPaper>

            @foreach (var family in group.Families)
            {
                <MudPaper Elevation="1" Class="pa-3 mb-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
                        <MudAvatar Color="Color.Primary" Size="Size.Small">@family.FamilyName[0]</MudAvatar>
                        <MudText Typo="Typo.subtitle2">@family.FamilyName</MudText>
                        @if (family.Role == MemberRole.Admin)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">@_t.FamilyAdminChip</MudChip>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-auto">
                            @_t.Joined @family.JoinedAt.ToLocalTime().ToString("dd MMM yyyy")
                        </MudText>
                        @if (AuthState.Value.IsGlobalAdmin)
                        {
                            <MudTooltip Text="@_t.RemoveFamilyFromGroup">
                                <MudIconButton Icon="@Icons.Material.Filled.GroupRemove"
                                               Size="Size.Medium"
                                               Color="Color.Error"
                                               OnClick="@(() => ConfirmRemoveFamily(family))" />
                            </MudTooltip>
                        }
                    </MudStack>

                    @if (family.Members.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_t.NoActiveMembers</MudText>
                    }
                    else
                    {
                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                            @foreach (var member in family.Members)
                            {
                                <MudTooltip Text="@($"{member.DisplayName} · {member.CurrentWeight:0.##}× · {member.CurrentTier}")">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(member.IsLinked ? Color.Success : Color.Default)"
                                             Icon="@(member.IsLinked ? Icons.Material.Filled.VerifiedUser : Icons.Material.Filled.PersonOff)">
                                        @member.DisplayName
                                    </MudChip>
                                </MudTooltip>
                            }
                        </MudStack>
                    }
                </MudPaper>
            }
        </ChildContent>
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    [Parameter] public Guid GroupId { get; set; }

    private AppText _t = new();
    private List<BreadcrumbItem> _crumbs = [];

    /// <summary>True when the logged-in user's FamilyMember has IsAdmin = true.</summary>
    private bool IsCallerFamilyAdmin => ProfileState.Value.MyProfile?.IsAdmin == true;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _t = await I18nText.GetTextTableAsync<AppText>(this);
        _crumbs =
        [
            new BreadcrumbItem(_t.GroupBreadcrumb, href: "/groups"),
            new BreadcrumbItem("Detail", href: null, disabled: true)
        ];

        Dispatcher.Dispatch(new LoadGroupDetailAction(GroupId));
        Dispatcher.Dispatch(new LoadActivitiesAction(GroupId));
        Dispatcher.Dispatch(new LoadGroupSettlementsAction(GroupId));

        if (ProfileState.Value.MyProfile is null)
            Dispatcher.Dispatch(new LoadMyProfileAction());

        if (FamilyState.Value.MyFamily is null)
            Dispatcher.Dispatch(new LoadMyFamilyAction());
    }

    protected override void OnParametersSet()
    {
        if (State.Value.SelectedGroup?.Id != GroupId)
        {
            Dispatcher.Dispatch(new LoadGroupDetailAction(GroupId));
            Dispatcher.Dispatch(new LoadActivitiesAction(GroupId));
            Dispatcher.Dispatch(new LoadGroupSettlementsAction(GroupId));
        }
    }

    private async Task OpenEditDialog()
    {
        var group = State.Value.SelectedGroup!;
        var parameters = new DialogParameters<EditGroupDialog>
        {
            { x => x.InitialName, group.Name },
            { x => x.InitialDescription, group.Description }
        };

        var dialog = await DialogService.ShowAsync<EditGroupDialog>(_t.EditGroup, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EditGroupFormModel form })
        {
            Dispatcher.Dispatch(new UpdateGroupAction(GroupId,
                new UpdateGroupRequest(form.Name, form.Description)));
        }
    }

    private async Task ConfirmRegenerate()
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.RegenerateInviteCode,
            _t.RegenerateInviteCodeConfirm,
            yesText: _t.RegenerateInviteCodeYes,
            cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new RegenerateInviteCodeAction(GroupId));
    }

    [Inject] IJSRuntime JS { get; set; } = default!;

    private async Task CopyInviteCode()
    {
        if (State.Value.SelectedGroup is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", State.Value.SelectedGroup.InviteCode);
    }

    private async Task OpenCreateActivityDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateActivityDialog>(_t.NewActivity);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ActivityFormModel form })
        {
            Dispatcher.Dispatch(new CreateActivityAction(GroupId,
                new CreateActivityRequest(form.Name, form.Description)));
        }
    }

    private async Task ConfirmLeave()
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.LeaveGroup,
            _t.LeaveGroupConfirm,
            yesText: _t.LeaveGroupYes,
            cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new LeaveGroupAction(GroupId));
    }

    private async Task ConfirmDelete()
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.DeleteGroup,
            _t.DeleteGroupConfirm,
            yesText: _t.DeleteGroupYes,
            cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new DeleteGroupAction(GroupId));
    }

    private async Task OpenAddFamilyDialog()
    {
        var existingIds = (State.Value.SelectedGroup?.Families ?? [])
            .Select(f => f.FamilyId)
            .ToHashSet();

        var parameters = new DialogParameters<AdminAddFamilyDialog>
        {
            { x => x.ExistingFamilyIds, existingIds }
        };

        var dialog = await DialogService.ShowAsync<AdminAddFamilyDialog>(_t.AddFamilyToGroup, parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: Guid familyId })
            Dispatcher.Dispatch(new AdminAddFamilyToGroupAction(GroupId, familyId));
    }

    private async Task ConfirmRemoveFamily(GroupFamilyDto family)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.RemoveFamilyFromGroup,
            _t.RemoveFamilyConfirm,
            yesText: _t.Remove,
            cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new AdminRemoveFamilyFromGroupAction(GroupId, family.FamilyId));
    }

    // ── Settlement confirm actions (from group view) ──────────────────────────

    private async Task ConfirmGroupSettlementSent(GroupSettlementSummaryDto settlement)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.MarkAsSent,
            $"Confirm that {settlement.PayerFamilyName} has sent {settlement.Amount:F2} {settlement.Currency} to {settlement.ReceiverFamilyName}?",
            yesText: _t.MarkSent,
            cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new ConfirmSentAction(GroupId, settlement.ActivityId, settlement.Id));
    }

    private async Task ConfirmGroupSettlementReceived(GroupSettlementSummaryDto settlement)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            _t.MarkAsReceived,
            $"Confirm that {settlement.ReceiverFamilyName} has received {settlement.Amount:F2} {settlement.Currency} from {settlement.PayerFamilyName}?",
            yesText: _t.MarkReceived,
            cancelText: _t.Cancel);

        if (confirmed == true)
            Dispatcher.Dispatch(new ConfirmReceivedAction(GroupId, settlement.ActivityId, settlement.Id));
    }

    private static string FormatSettlementAmount(decimal amount, string currency)
    {
        var symbol = currency switch { "EUR" => "€", "USD" => "$", "GBP" => "£", _ => currency + " " };
        return $"{symbol}{amount:N2}";
    }
}
