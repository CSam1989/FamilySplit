@page "/groups/{GroupId:guid}"
@using FamilySplit.Client.Store.Groups
@using FamilySplit.Client.Store.Activities
@using FamilySplit.Client.Store.FamilyMembers
@using FamilySplit.Client.Store.Auth
@using FamilySplit.Client.Services
@using FamilySplit.Domain.Enums
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IDispatcher Dispatcher
@inject IState<GroupState> State
@inject IState<ActivityState> ActivityState
@inject IState<FamilyMemberState> ProfileState
@inject IState<AuthState> AuthState
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Group — FamilySplit</PageTitle>

<RequireAuth />

@if (State.Value.IsLoading && State.Value.SelectedGroup is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    return;
}

@if (State.Value.ErrorMessage is not null && State.Value.SelectedGroup is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@State.Value.ErrorMessage</MudAlert>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/groups"))">Back to groups</MudButton>
    return;
}

@{
    var group = State.Value.SelectedGroup;
    if (group is null) return;
    var isAdmin = group.CallerFamilyRole == MemberRole.Admin;
}

<MudBreadcrumbs Items="_crumbs" Class="mb-2" />

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
    <MudText Typo="Typo.h5">@group.Name</MudText>
    @if (isAdmin)
    {
        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Admin</MudChip>
    }
</MudStack>

@if (group.Description is not null)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@group.Description</MudText>
}

@if (State.Value.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
              CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearGroupErrorAction()))">
        @State.Value.ErrorMessage
    </MudAlert>
}

<!-- Invite code card -->
<MudPaper Elevation="1" Class="pa-4 mb-6 d-flex flex-row align-center gap-3" Style="width:fit-content">
    <MudIcon Icon="@Icons.Material.Filled.VpnKey" Color="Color.Primary" />
    <div>
        <MudText Typo="Typo.caption" Color="Color.Secondary">Invite code</MudText>
        <MudText Typo="Typo.h6" Style="letter-spacing:0.25em">@group.InviteCode</MudText>
    </div>
    <MudTooltip Text="Copy invite code">
        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                       Size="Size.Small"
                       OnClick="CopyInviteCode" />
    </MudTooltip>
    @if (isAdmin)
    {
        <MudTooltip Text="Regenerate invite code">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                           Size="Size.Small"
                           Color="Color.Warning"
                           OnClick="ConfirmRegenerate" />
        </MudTooltip>
    }
</MudPaper>

<!-- Participating families -->
<MudText Typo="Typo.h6" Class="mb-3">
    Families
    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ml-1">@group.Families.Count</MudChip>
</MudText>

@foreach (var family in group.Families)
{
    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom" Color="Color.Primary" />
            <MudText Typo="Typo.subtitle1"><strong>@family.FamilyName</strong></MudText>
            @if (family.Role == MemberRole.Admin)
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">Admin</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Default" Size="Size.Small">Member</MudChip>
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-auto">
                Joined @family.JoinedAt.ToLocalTime().ToString("dd MMM yyyy")
            </MudText>
        </MudStack>

        @if (family.Members.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No active members.</MudText>
        }
        else
        {
            <MudTable Items="family.Members" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Weight</MudTh>
                    <MudTh>Tier</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate Context="member">
                    <MudTd DataLabel="Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Small" Color="Color.Primary">@member.DisplayName[0]</MudAvatar>
                            <MudText>@member.DisplayName</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Weight">@member.CurrentWeight.ToString("0.##")×</MudTd>
                    <MudTd DataLabel="Tier">
                        <WeightBadge Tier="member.CurrentTier" Weight="member.CurrentWeight" />
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (member.IsLinked)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                     Icon="@Icons.Material.Filled.VerifiedUser">Linked</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small"
                                     Icon="@Icons.Material.Filled.PersonOff">Pending</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
}

@if (isAdmin)
{
    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Edit"
               OnClick="OpenEditDialog"
               Class="mr-2 mb-6">
        Edit group
    </MudButton>
}
@if (IsCallerFamilyAdmin)
{
    <MudButton Variant="Variant.Outlined"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.ExitToApp"
               OnClick="ConfirmLeave"
               Class="mr-2 mb-6">
        Leave group
    </MudButton>
}
@if (AuthState.Value.IsGlobalAdmin)
{
    <MudButton Variant="Variant.Filled"
               Color="Color.Error"
               StartIcon="@Icons.Material.Filled.DeleteForever"
               OnClick="ConfirmDelete"
               Class="mr-2 mb-6">
        Delete group
    </MudButton>
}

<!-- ── Activities ──────────────────────────────────────────────────────────── -->
<MudDivider Class="mb-6" />

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
    <MudText Typo="Typo.h6">Activities</MudText>
    @if (ActivityState.Value.Activities.Count > 0)
    {
        <MudChip T="string" Size="Size.Small" Color="Color.Default">
            @ActivityState.Value.Activities.Count
        </MudChip>
    }
    <MudSpacer />
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreateActivityDialog">
        New activity
    </MudButton>
</MudStack>

@if (ActivityState.Value.ErrorMessage is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3" ShowCloseIcon="true"
              CloseIconClicked="@(() => Dispatcher.Dispatch(new ClearActivityErrorAction()))">
        @ActivityState.Value.ErrorMessage
    </MudAlert>
}

@if (ActivityState.Value.IsLoading && !ActivityState.Value.Activities.Any())
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
}
else if (!ActivityState.Value.Activities.Any())
{
    <MudPaper Elevation="0" Class="pa-5 d-flex flex-column align-center"
              Style="border: 1px dashed var(--mud-palette-divider);">
        <MudIcon Icon="@Icons.Material.Outlined.EventNote" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">No activities yet. Create one to start tracking shared costs.</MudText>
    </MudPaper>
}
else
{
    @foreach (var activity in ActivityState.Value.Activities)
    {
        var actStatusColor = activity.Status switch
        {
            ActivityStatus.Open   => Color.Success,
            ActivityStatus.Closed => Color.Default,
            ActivityStatus.Settled => Color.Info,
            _                     => Color.Default
        };

        <MudPaper Elevation="1" Class="pa-3 mb-3"
                  Style="cursor:pointer"
                  @onclick="@(() => Nav.NavigateTo($"/groups/{GroupId}/activities/{activity.Id}"))">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Primary" />
                <div style="flex:1">
                    <MudText Typo="Typo.subtitle2">@activity.Name</MudText>
                    @if (activity.Description is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@activity.Description</MudText>
                    }
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @activity.ParticipantCount participants
                        @if (activity.SubActivityCount > 0)
                        {
                            <span> · @activity.SubActivityCount sub-activit@(activity.SubActivityCount == 1 ? "y" : "ies")</span>
                        }
                        · created @activity.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                    </MudText>
                </div>
                <MudChip T="string" Color="@actStatusColor" Size="Size.Small">@activity.Status</MudChip>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Secondary" />
            </MudStack>
        </MudPaper>
    }
}

@code {
    [Parameter] public Guid GroupId { get; set; }

    private List<BreadcrumbItem> _crumbs = [];

    /// <summary>True when the logged-in user's FamilyMember has IsAdmin = true.</summary>
    private bool IsCallerFamilyAdmin => ProfileState.Value.MyProfile?.IsAdmin == true;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _crumbs =
        [
            new BreadcrumbItem("Groups", href: "/groups"),
            new BreadcrumbItem("Detail", href: null, disabled: true)
        ];

        Dispatcher.Dispatch(new LoadGroupDetailAction(GroupId));
        Dispatcher.Dispatch(new LoadActivitiesAction(GroupId));

        if (ProfileState.Value.MyProfile is null)
            Dispatcher.Dispatch(new LoadMyProfileAction());
    }

    protected override void OnParametersSet()
    {
        if (State.Value.SelectedGroup?.Id != GroupId)
        {
            Dispatcher.Dispatch(new LoadGroupDetailAction(GroupId));
            Dispatcher.Dispatch(new LoadActivitiesAction(GroupId));
        }
    }

    private async Task OpenEditDialog()
    {
        var group = State.Value.SelectedGroup!;
        var parameters = new DialogParameters<EditGroupDialog>
        {
            { x => x.InitialName, group.Name },
            { x => x.InitialDescription, group.Description }
        };

        var dialog = await DialogService.ShowAsync<EditGroupDialog>("Edit group", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EditGroupFormModel form })
        {
            Dispatcher.Dispatch(new UpdateGroupAction(GroupId,
                new UpdateGroupRequest(form.Name, form.Description)));
        }
    }

    private async Task ConfirmRegenerate()
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Regenerate invite code",
            "The old invite code will stop working immediately. Continue?",
            yesText: "Regenerate",
            cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new RegenerateInviteCodeAction(GroupId));
    }

    [Inject] IJSRuntime JS { get; set; } = default!;

    private async Task CopyInviteCode()
    {
        if (State.Value.SelectedGroup is null) return;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", State.Value.SelectedGroup.InviteCode);
    }

    private async Task OpenCreateActivityDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateActivityDialog>("New activity");
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ActivityFormModel form })
        {
            Dispatcher.Dispatch(new CreateActivityAction(GroupId,
                new CreateActivityRequest(form.Name, form.Description)));
        }
    }

    private async Task ConfirmLeave()
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Leave group",
            "Your family will be removed from this group. This cannot be undone. Continue?",
            yesText: "Leave group",
            cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new LeaveGroupAction(GroupId));
    }

    private async Task ConfirmDelete()
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Delete group",
            $"This will permanently delete \"{State.Value.SelectedGroup?.Name}\" and all its activities. This cannot be undone. Continue?",
            yesText: "Delete group",
            cancelText: "Cancel");

        if (confirmed == true)
            Dispatcher.Dispatch(new DeleteGroupAction(GroupId));
    }
}
