@inject I18nText I18nText

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@_t.RenameFamilyTitle</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string"
                          @bind-Value="_name"
                          Label="@_t.FamilyName"
                          Required="true"
                          RequiredError="@_t.FamilyNameRequired"
                          MaxLength="100"
                          Counter="100"
                          Immediate="true"
                          Autofocus="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@_t.Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!_isValid)">
            @_t.Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string InitialName { get; set; } = "";

    private MudForm _form    = default!;
    private bool    _isValid;
    private string  _name    = "";
    private AppText _t       = new();

    protected override void OnParametersSet() => _name = InitialName;

    protected override async Task OnInitializedAsync()
    {
        _t = await I18nText.GetTextTableAsync<AppText>(this);
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        MudDialog.Close(DialogResult.Ok(_name));
    }

    private void Cancel() => MudDialog.Cancel();
}
