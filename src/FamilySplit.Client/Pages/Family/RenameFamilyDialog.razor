<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Rename family</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField T="string"
                          @bind-Value="_name"
                          Label="Family name"
                          Required="true"
                          RequiredError="Family name is required."
                          MaxLength="100"
                          Counter="100"
                          Immediate="true"
                          Autofocus="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!_isValid)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string InitialName { get; set; } = "";

    private MudForm _form    = default!;
    private bool    _isValid;
    private string  _name    = "";

    protected override void OnParametersSet() => _name = InitialName;

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        MudDialog.Close(DialogResult.Ok(_name.Trim()));
    }

    private void Cancel() => MudDialog.Cancel();
}
