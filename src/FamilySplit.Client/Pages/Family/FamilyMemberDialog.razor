@using FamilySplit.Client.Pages.Family

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@_title</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">

            <MudTextField T="string"
                          @bind-Value="_model.DisplayName"
                          Label="Name"
                          Required="true"
                          RequiredError="Name is required."
                          MaxLength="100"
                          Counter="100"
                          Immediate="true"
                          Class="mb-4" />

            <MudTextField T="string"
                          @bind-Value="_model.Email"
                          Label="Email (optional)"
                          InputType="InputType.Email"
                          MaxLength="255"
                          HelperText="Set for adults who will log in; leave blank for children."
                          Immediate="true"
                          Class="mb-4"
                          Validation="@(new Func<string?, IEnumerable<string>>(ValidateEmail))" />

            <MudDatePicker @bind-Date="_dobDate"
                           Label="Date of birth (optional)"
                           MaxDate="DateTime.Today"
                           Placeholder="Leave blank if unknown"
                           Class="mb-4" />

            <MudCheckBox T="bool"
                         @bind-Value="_model.UseOverride"
                         Label="Set a custom weight (overrides age tier)"
                         Class="mb-2" />

            @if (_model.UseOverride)
            {
                <MudNumericField T="decimal?"
                                 @bind-Value="_model.WeightOverride"
                                 Label="Custom weight"
                                 Min="0.01m"
                                 Max="10m"
                                 Step="0.05m"
                                 Format="0.##"
                                 HelperText="1.00 = one full adult share"
                                 Class="mb-4"
                                 Validation="@(new Func<decimal?, IEnumerable<string>>(ValidateWeightOverride))" />
            }

            @if (ShowAdminToggle)
            {
                <MudCheckBox T="bool"
                             @bind-Value="_model.IsAdmin"
                             Label="Family admin (can manage members)"
                             Class="mb-2" />
            }

        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!_isValid)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Pre-populate the form when editing an existing member.</summary>
    [Parameter] public FamilyMemberFormModel? InitialValues { get; set; }

    /// <summary>Whether to show the admin toggle. Pass false for non-admin callers.</summary>
    [Parameter] public bool ShowAdminToggle { get; set; } = true;

    private MudForm               _form    = default!;
    private bool                  _isValid;
    private FamilyMemberFormModel _model   = new();
    private DateTime?             _dobDate;
    private string                _title   = "Family member";

    protected override void OnParametersSet()
    {
        if (InitialValues is not null)
        {
            _model = new FamilyMemberFormModel
            {
                DisplayName    = InitialValues.DisplayName,
                Email          = InitialValues.Email,
                UseOverride    = InitialValues.UseOverride,
                WeightOverride = InitialValues.WeightOverride ?? 1.00m,
                IsAdmin        = InitialValues.IsAdmin
            };
            _dobDate = InitialValues.DateOfBirth.HasValue
                ? InitialValues.DateOfBirth.Value.ToDateTime(TimeOnly.MinValue)
                : null;
            _title = "Edit member";
        }
        else
        {
            _title = "Add member";
        }
    }

    private static IEnumerable<string> ValidateEmail(string? email)
    {
        if (string.IsNullOrEmpty(email)) yield break;
        if (email.Length > 255) yield return "Email cannot exceed 255 characters.";
        var attr = new System.ComponentModel.DataAnnotations.EmailAddressAttribute();
        if (!attr.IsValid(email)) yield return "Email must be a valid email address.";
    }

    private static IEnumerable<string> ValidateWeightOverride(decimal? weight)
    {
        if (weight is null) yield break;
        if (weight.Value <= 0m || weight.Value > 10m)
            yield return "Weight override must be between 0.01 and 10.";
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _model.DateOfBirth = _dobDate.HasValue ? DateOnly.FromDateTime(_dobDate.Value) : null;
        if (!_model.UseOverride) _model.WeightOverride = null;

        MudDialog.Close(DialogResult.Ok(_model));
    }

    private void Cancel() => MudDialog.Cancel();
}
