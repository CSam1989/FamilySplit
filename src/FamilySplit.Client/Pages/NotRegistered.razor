@page "/not-registered"
@inject I18nText I18nText

<PageTitle>Account not registered — FamilySplit</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <MudIcon Icon="@Icons.Material.Filled.PersonOff"
             Color="Color.Warning"
             Style="font-size:5rem;"
             Class="mb-4" />

    <MudText Typo="Typo.h5" Class="mb-2">@_t.AccountNotRegistered</MudText>

    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        @_t.NotRegisteredMessage
    </MudText>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Href="/"
               StartIcon="@Icons.Material.Filled.Home">
        @_t.BackToDashboard
    </MudButton>
</MudContainer>

@code {
    private AppText _t = new();

    protected override async Task OnInitializedAsync()
    {
        _t = await I18nText.GetTextTableAsync<AppText>(this);
    }
}
