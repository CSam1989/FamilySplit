@using FamilySplit.Client.Store.Auth
@using FamilySplit.Client.Pages.Activities
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject NavigationManager Nav
@inject IState<AuthState> AuthState
@inject IDialogService DialogService
@inject I18nText I18nText

@if (AuthState.Value.IsAuthenticated)
{
    <nav class="fs-bottom-nav" role="navigation" aria-label="Main navigation">

        <!-- Home -->
        <a href="/" class="fs-nav-item @IsActive("", exact: true)" aria-label="@_t.NavHome">
            <span class="fs-nav-icon">
                @if (IsActive("", exact: true) == "active")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Home" Style="font-size:22px" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Home" Style="font-size:22px" />
                }
            </span>
            <span class="fs-nav-label">@_t.NavHome</span>
        </a>

        <!-- Groups -->
        <a href="/groups" class="fs-nav-item @IsActive("groups")" aria-label="@_t.NavGroups">
            <span class="fs-nav-icon">
                @if (IsActive("groups") == "active")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Style="font-size:22px" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Groups" Style="font-size:22px" />
                }
            </span>
            <span class="fs-nav-label">@_t.NavGroups</span>
        </a>

        <!-- FAB — quick add expense -->
        <div class="fs-nav-fab-wrap">
            <button class="fs-nav-fab" title="@_t.NavAddExpense" aria-label="@_t.NavAddExpense"
                    @onclick="OpenQuickAddAsync">
                <MudIcon Icon="@Icons.Material.Rounded.Add" Style="font-size:28px;color:white" />
            </button>
        </div>

        <!-- Family -->
        <a href="/families/mine" class="fs-nav-item @IsActive("families")" aria-label="@_t.NavFamily">
            <span class="fs-nav-icon">
                @if (IsActive("families") == "active")
                {
                    <MudIcon Icon="@Icons.Material.Filled.FamilyRestroom" Style="font-size:22px" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.FamilyRestroom" Style="font-size:22px" />
                }
            </span>
            <span class="fs-nav-label">@_t.NavFamily</span>
        </a>

        <!-- Settings -->
        <a href="/settings" class="fs-nav-item @IsActive("settings")" aria-label="@_t.NavSettings">
            <span class="fs-nav-icon">
                @if (IsActive("settings") == "active")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Style="font-size:22px" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Settings" Style="font-size:22px" />
                }
            </span>
            <span class="fs-nav-label">@_t.NavSettings</span>
        </a>

    </nav>
}

@code {
    private AppText _t = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _t = await I18nText.GetTextTableAsync<AppText>(this);
        Nav.LocationChanged += (_, _) => StateHasChanged();
    }

    private string IsActive(string segment, bool exact = false)
    {
        var path = new Uri(Nav.Uri).AbsolutePath.Trim('/');

        if (exact)
            return path == segment.Trim('/') ? "active" : "";

        return path.StartsWith(segment.Trim('/'), StringComparison.OrdinalIgnoreCase) && segment.Length > 0
            ? "active"
            : "";
    }

    private async Task OpenQuickAddAsync()
    {
        var options = new DialogOptions
        {
            FullScreen        = false,
            Position          = DialogPosition.BottomCenter,
            MaxWidth          = MaxWidth.Small,
            FullWidth         = true,
            CloseOnEscapeKey  = true,
            BackdropClick     = true,
        };
        await DialogService.ShowAsync<QuickExpenseDialog>(_t.NavAddExpense, options);
    }
}
