@inherits LayoutComponentBase
@using FamilySplit.Client.Store.Auth
@using FamilySplit.Client.Services
@using FamilySplit.Client.Components
@using FamilySplit.Client.Theme
@inject IState<AuthState> AuthState
@inject NotificationHubConnection HubConnection
@inject ISnackbar Snackbar
@inject ThemeService ThemeService
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudThemeProvider Theme="AppTheme.Theme" IsDarkMode="@ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.ExtraSmall" />
<MudSnackbarProvider />

<MudLayout>

    <!-- ── App bar ─────────────────────────────────────────────────────── -->
    <MudAppBar Elevation="0" Color="Color.Surface"
               Style="border-bottom:1px solid var(--fs-border); height:var(--fs-appbar-height)">

        <!-- Hamburger: desktop only (CSS-hidden on mobile — no JS flash) -->
        <MudIconButton Icon="@Icons.Material.Rounded.Menu"
                       Color="Color.Default"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       Class="fs-desktop-only"
                       aria-label="Toggle menu" />

        <!-- Logo mark + title: always visible -->
        <div style="display:flex;align-items:center;gap:8px;margin-left:4px">
            <div style="width:28px;height:28px;border-radius:8px;background:var(--fs-primary);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <img src="/images/logo-mark.svg" width="16" height="16" alt="FamilySplit" />
            </div>
            <span style="font-weight:700;font-size:1.0625rem;letter-spacing:-0.02em;color:var(--fs-text-primary)">
                FamilySplit
            </span>
        </div>

        <MudSpacer />

        <!-- User info (auth-gated) -->
        @if (AuthState.Value.IsAuthenticated && AuthState.Value.CurrentUser is { } user)
        {
            <!-- Avatar: mobile only -->
            <div class="fs-mobile-only" style="display:flex;align-items:center">
                @if (user.AvatarUrl is { } av)
                {
                    <img src="@av" alt="@user.DisplayName"
                         style="width:30px;height:30px;border-radius:50%;object-fit:cover;margin-right:8px" />
                }
                else
                {
                    <MudAvatar Style="width:30px;height:30px;font-size:0.75rem;background:var(--fs-primary-light);color:var(--fs-primary);margin-right:8px">
                        @user.DisplayName.Substring(0, 1).ToUpper()
                    </MudAvatar>
                }
            </div>
            <!-- Name + badge: desktop only -->
            <div class="fs-desktop-only" style="display:flex;align-items:center;gap:6px;margin-right:4px">
                <MudText Typo="Typo.body2" Style="color:var(--fs-text-secondary)">@user.DisplayName</MudText>
                @if (user.IsGlobalAdmin)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Admin</MudChip>
                }
            </div>
        }
    </MudAppBar>

    <!-- ── Sidebar: persistent on desktop, hidden on mobile ───────────── -->
    <!--
        ErrorBoundary catches the MudBlazor WASM race condition where MudDrawer calls
        getBoundingClientRect before its JS element ref is registered on firstRender.
        Recover() in OnAfterRenderAsync retries the render; the second pass always
        succeeds because JS interop is ready by then.
    -->
    <ErrorBoundary @ref="_drawerBoundary">
        <ChildContent>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="0"
                       Variant="DrawerVariant.Responsive"
                       Breakpoint="Breakpoint.Md"
                       Style="border-right:1px solid var(--fs-border)">
                <div class="fs-sidebar-logo">
                    <div class="fs-sidebar-logo-mark">
                        <img src="/images/logo-mark.svg" width="18" height="18" alt="FamilySplit" />
                    </div>
                    <span class="fs-sidebar-logo-text">FamilySplit</span>
                </div>
                <NavMenu />
            </MudDrawer>
        </ChildContent>
        <ErrorContent>
            @* Silently absorb the transient JS race condition — drawer recovers on next render *@
        </ErrorContent>
    </ErrorBoundary>

    <!-- ── Page content ────────────────────────────────────────────────── -->
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium"
                      Class="fs-page-content"
                      Style="padding-top:24px;padding-bottom:32px">
            <PushPermissionBanner />
            @Body
        </MudContainer>
    </MudMainContent>

    <!-- ── Mobile bottom nav (CSS-hidden on desktop) ──────────────────── -->
    <div class="fs-mobile-only">
        <BottomNav />
    </div>

</MudLayout>

@code {
    private bool _drawerOpen = true;
    private ErrorBoundary? _drawerBoundary;
    private bool _hubConnected;
    private bool _themeInitialized;
    private DotNetObjectReference<MainLayout>? _selfRef;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized()
    {
        ThemeService.OnChanged += OnThemeChanged;
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    [JSInvokable]
    public void OnSwUpdated()
    {
        Snackbar.Add(builder =>
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "style", "display:flex;align-items:center;gap:12px");

            builder.OpenElement(2, "span");
            builder.AddContent(3, "A new version is available.");
            builder.CloseElement();

            builder.OpenComponent<MudButton>(4);
            builder.AddAttribute(5, "Variant", Variant.Filled);
            builder.AddAttribute(6, "Color", Color.Primary);
            builder.AddAttribute(7, "Size", Size.Small);
            builder.AddAttribute(8, "OnClick", EventCallback.Factory.Create(this, () => JS.InvokeVoidAsync("FamilySplitSw.reload")));
            builder.AddContent(9, "Reload");
            builder.CloseComponent();

            builder.CloseElement();
        }, Severity.Info, config =>
        {
            config.RequireInteraction        = true;
            config.ShowCloseIcon             = false;
            config.VisibleStateDuration      = int.MaxValue;
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("FamilySplitSw.registerUpdateListener", _selfRef);
        }

        // Recover the ErrorBoundary so the drawer re-renders after the transient
        // JS race condition on first WASM load. The second render always succeeds.
        _drawerBoundary?.Recover();

        // Initialize theme once — detect system preference and apply saved setting.
        if (firstRender && !_themeInitialized)
        {
            _themeInitialized = true;
            var systemIsDark = await JS.InvokeAsync<bool>(
                "eval", "window.matchMedia('(prefers-color-scheme: dark)').matches");
            await ThemeService.InitAsync(systemIsDark);
            StateHasChanged();
        }

        // Connect to the SignalR hub as soon as the user is authenticated.
        if (AuthState.Value.IsAuthenticated && !_hubConnected)
        {
            _hubConnected = true;
            HubConnection.OnNotificationReceived += ShowNotificationToast;
            await HubConnection.ConnectAsync();
        }
        else if (!AuthState.Value.IsAuthenticated && _hubConnected)
        {
            _hubConnected = false;
            HubConnection.OnNotificationReceived -= ShowNotificationToast;
            await HubConnection.DisconnectAsync();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void ShowNotificationToast(NotificationMessage msg)
    {
        Snackbar.Add(
            $"**{msg.Title}** — {msg.Message}",
            Severity.Info,
            config =>
            {
                config.ShowCloseIcon     = true;
                config.VisibleStateDuration = 6000;
                config.HideTransitionDuration = 300;
                config.ShowTransitionDuration  = 300;
            });
    }

    public async ValueTask DisposeAsync()
    {
        ThemeService.OnChanged -= OnThemeChanged;
        HubConnection.OnNotificationReceived -= ShowNotificationToast;
        await HubConnection.DisconnectAsync();
        _selfRef?.Dispose();
    }

}
