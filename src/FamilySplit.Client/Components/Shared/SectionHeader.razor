@* Section heading row: left-aligned title + optional right-aligned action slot. *@

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
    @if (LeadingIcon is not null)
    {
        <MudIcon Icon="@LeadingIcon" Color="@LeadingIconColor" Size="Size.Small" />
    }
    <MudText Typo="Typo.h6">@Title</MudText>
    <MudSpacer />
    @if (Actions is not null)
    {
        @Actions
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public string          Title            { get; set; } = string.Empty;
    [Parameter]                 public string?         LeadingIcon      { get; set; }
    [Parameter]                 public Color           LeadingIconColor { get; set; } = Color.Default;

    /// <summary>Buttons or other controls rendered on the right side of the header.</summary>
    [Parameter] public RenderFragment? Actions { get; set; }
}
