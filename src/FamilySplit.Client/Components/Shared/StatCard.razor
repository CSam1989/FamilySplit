@* Centred stat tile: icon on top, large value, small label underneath. *@

<MudPaper Elevation="1"
          Class="pa-4 d-flex flex-column align-center"
          Style="text-align:center">
    <MudIcon Icon="@Icon" Color="@IconColor" Class="mb-1" />
    <MudText Typo="Typo.h5"><strong>@Value</strong></MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary">@Label</MudText>
</MudPaper>

@code {
    [Parameter, EditorRequired] public string Icon      { get; set; } = string.Empty;
    [Parameter]                 public Color  IconColor { get; set; } = Color.Default;
    [Parameter, EditorRequired] public string Value     { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Label     { get; set; } = string.Empty;
}
