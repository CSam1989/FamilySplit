@* Admin / Member role chip for a FamilyMember. *@
@inject I18nText I18nText

<MudChip T="string"
         Color="@(IsAdmin ? Color.Warning : Color.Default)"
         Size="Size.Small">
    @(IsAdmin ? _t.FamilyAdminLabel : _t.MemberLabel)
</MudChip>

@code {
    [Parameter, EditorRequired] public bool IsAdmin { get; set; }

    private AppText _t = new();

    protected override async Task OnInitializedAsync()
    {
        _t = await I18nText.GetTextTableAsync<AppText>(this);
    }
}
