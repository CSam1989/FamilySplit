{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Warning",
        "FamilySplit": "Information"
      }
    },
    "Properties": {
      "Application": "FamilySplit.Api"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5001",
      "http://localhost:5000"
    ]
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Jwt": {
    "Issuer": "familysplit",
    "Audience": "familysplit-client",
    "LifetimeMinutes": 15,
    "RefreshLifetimeDays": 30,
    "SigningKey": ""
  },
  "Push": {
    "Vapid": {
      "Subject": "mailto:noreply@familysplit.app",
      "PublicKey": "",
      "PrivateKey": ""
    }
  },
  "OAuth": {
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "AuthorizeUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "TokenUrl": "https://oauth2.googleapis.com/token",
      "UserInfoUrl": "https://openidconnect.googleapis.com/v1/userinfo"
    }
  }
}
