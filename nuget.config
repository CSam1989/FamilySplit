<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Package source mapping is required when Central Package Management is enabled
    alongside multiple NuGet sources (NU1507).

    All packages in this solution are published on nuget.org, so the wildcard
    pattern routes everything there by default.  Add explicit Coteng nexus entries
    below for any internal/private packages when the time comes.
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
